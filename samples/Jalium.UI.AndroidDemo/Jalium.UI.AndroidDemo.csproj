<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0-android</TargetFramework>
		<OutputType>Exe</OutputType>
		<ApplicationId>com.jalium.ui.androiddemo</ApplicationId>
		<ApplicationVersion>1</ApplicationVersion>
		<ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
		<SupportedOSPlatformVersion>24</SupportedOSPlatformVersion>
		<RootNamespace>Jalium.UI.AndroidDemo</RootNamespace>
		<IsPackable>false</IsPackable>
		<!-- Disable fast deployment (run-as not supported on some devices) -->
		<EmbedAssembliesIntoApk>true</EmbedAssembliesIntoApk>
	</PropertyGroup>

	<!-- Reference Jalium.UI Android entry package (includes all components + native .so) -->
	<ItemGroup>
		<ProjectReference Include="..\..\src\packaging\Jalium.UI.Android\Jalium.UI.Android.csproj" />
		<!-- Local project-reference builds need the implementation assembly as a
		     compile-time bridge for types forwarded by the facade projects. NuGet
		     consumers receive this transitively through package dependencies. -->
		<ProjectReference Include="..\..\src\managed\Jalium.UI.Managed\Jalium.UI.Managed.csproj"
		                  SetTargetFramework="TargetFramework=net10.0" />
	</ItemGroup>

</Project>
