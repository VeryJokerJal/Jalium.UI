{
  "Greeting": {
    "Message": "欢迎使用 Jalium.UI AppBuilder",
    "Author": "Jalium Team"
  },
  "Jalium": {
    "Metrics": {
      "Enabled": true,
      "FpsWindowFrames": 30
    },
    "Render": {
      "Backend": "Auto",
      "DebugRender": false
    },
    "Mvvm": {
      "EnableViewFactory": true,
      "EnableAutoWireDataContext": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Jalium.UI.HostingDemo": "Debug"
    }
  }
}
