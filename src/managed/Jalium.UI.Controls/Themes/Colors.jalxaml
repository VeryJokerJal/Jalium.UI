                <GradientStop Offset="0" Color="#FF2A4A3A" />
                <GradientStop Offset="1" Color="#FF2A503A" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="SystemControlDisabledBaseHighBrush" Color="#FFFFFFFF" />
