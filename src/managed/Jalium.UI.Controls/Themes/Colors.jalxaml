            <SolidColorBrush x:Key="TextTertiary" Color="#AEAEB2" />
            <SolidColorBrush x:Key="TextDisabled" Color="#636366" />
            <!-- On-accent foreground. The accent is a fixed dark green
                 (#207245 -> #1C8043) in BOTH themes, so on-accent text and
                 glyphs (e.g. the CheckBox check mark / RadioButton dot) must be
                 white here too — not the WinUI dark-theme black that assumes a
                 light accent. Keep this in sync with the Light dictionary. -->
            <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextPlaceholder" Color="#AEAEB2" />

            <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,0">
