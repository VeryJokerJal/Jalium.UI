<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Resolve the native payload from the target RID, never from whichever
       runtimes directory happens to exist first in the package. -->
  <PropertyGroup Condition="'$(UseJaliumNativeAot)' != 'true'">
    <_JaliumInteropRequestedRid Condition="'$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier)</_JaliumInteropRequestedRid>
    <_JaliumInteropRequestedRid Condition="'$(_JaliumInteropRequestedRid)' == ''">$(NETCoreSdkRuntimeIdentifier)</_JaliumInteropRequestedRid>
    <_JaliumInteropIsLinuxDistro>$([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('linux'))</_JaliumInteropIsLinuxDistro>
    <_JaliumInteropIsLinuxDistro Condition="$([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('ubuntu')) or $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('debian')) or $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('fedora')) or $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('rhel')) or $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('centos')) or $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('opensuse')) or $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('sles')) or $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('alpine'))">true</_JaliumInteropIsLinuxDistro>

    <_JaliumInteropResolvedRid Condition="Exists('$(MSBuildThisFileDirectory)../runtimes/$(_JaliumInteropRequestedRid)/native')">$(_JaliumInteropRequestedRid)</_JaliumInteropResolvedRid>
    <_JaliumInteropResolvedRid Condition="'$(_JaliumInteropResolvedRid)' == '' and $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('win')) and $([System.String]::Copy('$(_JaliumInteropRequestedRid)').EndsWith('-x64'))">win-x64</_JaliumInteropResolvedRid>
    <_JaliumInteropResolvedRid Condition="'$(_JaliumInteropResolvedRid)' == '' and $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('win')) and $([System.String]::Copy('$(_JaliumInteropRequestedRid)').EndsWith('-arm64'))">win-arm64</_JaliumInteropResolvedRid>
    <_JaliumInteropResolvedRid Condition="'$(_JaliumInteropResolvedRid)' == '' and ($([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('linux-musl')) or $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('alpine'))) and $([System.String]::Copy('$(_JaliumInteropRequestedRid)').EndsWith('-x64'))">linux-musl-x64</_JaliumInteropResolvedRid>
    <_JaliumInteropResolvedRid Condition="'$(_JaliumInteropResolvedRid)' == '' and ($([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('linux-musl')) or $([System.String]::Copy('$(_JaliumInteropRequestedRid)').StartsWith('alpine'))) and $([System.String]::Copy('$(_JaliumInteropRequestedRid)').EndsWith('-arm64'))">linux-musl-arm64</_JaliumInteropResolvedRid>
    <_JaliumInteropResolvedRid Condition="'$(_JaliumInteropResolvedRid)' == '' and '$(_JaliumInteropIsLinuxDistro)' == 'true' and $([System.String]::Copy('$(_JaliumInteropRequestedRid)').EndsWith('-x64'))">linux-x64</_JaliumInteropResolvedRid>
    <_JaliumInteropResolvedRid Condition="'$(_JaliumInteropResolvedRid)' == '' and '$(_JaliumInteropIsLinuxDistro)' == 'true' and $([System.String]::Copy('$(_JaliumInteropRequestedRid)').EndsWith('-arm64'))">linux-arm64</_JaliumInteropResolvedRid>

    <_JaliumInteropNativeDir Condition="'$(_JaliumInteropResolvedRid)' != '' and Exists('$(MSBuildThisFileDirectory)../runtimes/$(_JaliumInteropResolvedRid)/native')">$(MSBuildThisFileDirectory)../runtimes/$(_JaliumInteropResolvedRid)/native</_JaliumInteropNativeDir>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseJaliumNativeAot)' != 'true' and '$(_JaliumInteropNativeDir)' != ''">
    <None Include="$(_JaliumInteropNativeDir)/*.dll;$(_JaliumInteropNativeDir)/*.so"
          Link="%(Filename)%(Extension)"
          CopyToOutputDirectory="PreserveNewest"
          CopyToPublishDirectory="PreserveNewest"
          Visible="false" />
  </ItemGroup>
</Project>
