{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "JALIUM_BUILD_DEMOS": false,
        "JALIUM_BUILD_STATIC": false
      }
    },
    {
      "name": "linux-x64",
      "displayName": "Linux glibc x64",
      "description": "Native x64 glibc build. Run on x64 glibc or supply an x64 glibc toolchain.",
      "inherits": "linux-base",
      "cacheVariables": {
        "JALIUM_LINUX_LIBC": "glibc",
        "JALIUM_NATIVE_RID": "linux-x64"
      }
    },
    {
      "name": "linux-arm64",
      "displayName": "Linux glibc arm64",
      "description": "Native arm64 glibc build. Run on arm64 glibc or supply an arm64 glibc toolchain.",
      "inherits": "linux-base",
      "cacheVariables": {
        "JALIUM_LINUX_LIBC": "glibc",
        "JALIUM_NATIVE_RID": "linux-arm64"
      }
    },
    {
      "name": "linux-musl-x64",
      "displayName": "Linux musl x64",
      "description": "Native x64 musl build. Run in an x64 Alpine/musl environment or supply a musl toolchain.",
      "inherits": "linux-base",
      "cacheVariables": {
        "JALIUM_LINUX_LIBC": "musl",
        "JALIUM_NATIVE_RID": "linux-musl-x64"
      }
    },
    {
      "name": "linux-musl-arm64",
      "displayName": "Linux musl arm64",
      "description": "Native arm64 musl build. Run in an arm64 Alpine/musl environment or supply a musl toolchain.",
      "inherits": "linux-base",
      "cacheVariables": {
        "JALIUM_LINUX_LIBC": "musl",
        "JALIUM_NATIVE_RID": "linux-musl-arm64"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-linux-x64",
      "configurePreset": "linux-x64"
    },
    {
      "name": "build-linux-arm64",
      "configurePreset": "linux-arm64"
    },
    {
      "name": "build-linux-musl-x64",
      "configurePreset": "linux-musl-x64"
    },
    {
      "name": "build-linux-musl-arm64",
      "configurePreset": "linux-musl-arm64"
    }
  ]
}
