<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-android</TargetFramework>
    <RootNamespace>Jalium.UI</RootNamespace>
    <AssemblyName>Jalium.UI.Android</AssemblyName>
    <Description>Jalium.UI Android entry package. References all Jalium.UI components built for Android, including native .so libraries.</Description>
    <SupportedOSPlatformVersion>24</SupportedOSPlatformVersion>

    <!-- NuGet Package Configuration -->
    <IsPackable>true</IsPackable>
    <PackageId>Jalium.UI.Android</PackageId>
    <IncludeSymbols>false</IncludeSymbols>
    <SuppressDependenciesWhenPacking>false</SuppressDependenciesWhenPacking>

    <!-- Path to Android native libs (override with JaliumAndroidNativeRoot for custom locations) -->
    <JaliumAndroidNativeRoot Condition="'$(JaliumAndroidNativeRoot)' == ''">$(MSBuildProjectDirectory)\..\..\..\samples\Jalium.UI.AndroidDemo\libs</JaliumAndroidNativeRoot>
  </PropertyGroup>

  <!-- Reference all Jalium.UI runtime packages (force net10.0 build for cross-platform core libs) -->
  <ItemGroup>
    <ProjectReference Include="..\..\managed\Jalium.UI.Core\Jalium.UI.Core.csproj" SetTargetFramework="TargetFramework=net10.0" />
    <ProjectReference Include="..\..\managed\Jalium.UI.Media\Jalium.UI.Media.csproj" SetTargetFramework="TargetFramework=net10.0" />
    <ProjectReference Include="..\..\managed\Jalium.UI.Input\Jalium.UI.Input.csproj" SetTargetFramework="TargetFramework=net10.0" />
    <ProjectReference Include="..\..\managed\Jalium.UI.Interop\Jalium.UI.Interop.csproj" SetTargetFramework="TargetFramework=net10.0" />
    <ProjectReference Include="..\..\managed\Jalium.UI.Managed\Jalium.UI.Managed.csproj" SetTargetFramework="TargetFramework=net10.0" />
    <ProjectReference Include="..\..\managed\Jalium.UI.Controls\Jalium.UI.Controls.csproj" SetTargetFramework="TargetFramework=net10.0" />
    <ProjectReference Include="..\..\managed\Jalium.UI.Xaml\Jalium.UI.Xaml.csproj" SetTargetFramework="TargetFramework=net10.0" />
    <ProjectReference Include="..\..\managed\Jalium.UI.Gpu\Jalium.UI.Gpu.csproj" SetTargetFramework="TargetFramework=net10.0" />
  </ItemGroup>

  <!-- Include build tools -->
  <ItemGroup>
    <ProjectReference Include="..\..\managed\Jalium.UI.Build\Jalium.UI.Build.csproj" ReferenceOutputAssembly="false" PrivateAssets="none" />
    <ProjectReference Include="..\..\managed\Jalium.UI.Xaml.SourceGenerator\Jalium.UI.Xaml.SourceGenerator.csproj"
                      PrivateAssets="none"
                      UndefineProperties="PublishAot;PublishTrimmed;PublishSingleFile;PublishReadyToRun;SelfContained;RuntimeIdentifier;RuntimeIdentifiers" />
  </ItemGroup>

  <!-- Ensure Jalium.UI.Build appears as a NuGet dependency -->
  <ItemGroup>
    <PackageReference Include="Jalium.UI.Build" Version="$(Version)" PrivateAssets="none" />
  </ItemGroup>

  <!-- Android native .so libraries for arm64-v8a. Every entry is required:
       build-android.sh writes the completeness stamp only after validating the
       whole ABI payload, so a failed/stale native build can never pack a
       partial AAR. -->
  <ItemGroup>
    <_JaliumAndroidPackageStamp Include="$(JaliumAndroidNativeRoot)\.jalium-android-payload-complete" />
    <_JaliumAndroidPayloadStamp Include="$(JaliumAndroidNativeRoot)\arm64-v8a\.jalium-native-complete" Abi="arm64-v8a" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\arm64-v8a\libjalium.native.core.so" Abi="arm64-v8a"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\arm64-v8a\libjalium.native.platform.so" Abi="arm64-v8a"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\arm64-v8a\libjalium.native.media.core.so" Abi="arm64-v8a"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\arm64-v8a\libjalium.native.vulkan.so" Abi="arm64-v8a"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\arm64-v8a\libjalium.native.software.so" Abi="arm64-v8a"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\arm64-v8a\libjalium.native.text.so" Abi="arm64-v8a"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\arm64-v8a\libjalium.native.media.so" Abi="arm64-v8a"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\arm64-v8a\libc++_shared.so" Abi="arm64-v8a"
                          JaliumRequired="true" />
  </ItemGroup>

  <!-- Android native .so libraries for x86_64 (emulator) -->
  <ItemGroup>
    <_JaliumAndroidPayloadStamp Include="$(JaliumAndroidNativeRoot)\x86_64\.jalium-native-complete" Abi="x86_64" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\x86_64\libjalium.native.core.so" Abi="x86_64"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\x86_64\libjalium.native.platform.so" Abi="x86_64"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\x86_64\libjalium.native.media.core.so" Abi="x86_64"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\x86_64\libjalium.native.vulkan.so" Abi="x86_64"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\x86_64\libjalium.native.software.so" Abi="x86_64"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\x86_64\libjalium.native.text.so" Abi="x86_64"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\x86_64\libjalium.native.media.so" Abi="x86_64"
                          JaliumRequired="true" />
    <AndroidNativeLibrary Include="$(JaliumAndroidNativeRoot)\x86_64\libc++_shared.so" Abi="x86_64"
                          JaliumRequired="true" />
  </ItemGroup>

  <Target Name="ValidateJaliumAndroidNativePayload"
          BeforeTargets="PrepareForBuild;_IntermediatePack">
    <Error Condition="!Exists('%(_JaliumAndroidPackageStamp.Identity)')"
           Text="The dual-ABI Jalium Android package payload is incomplete. Missing package-set stamp: '%(_JaliumAndroidPackageStamp.Identity)'. Run 'src/native/build-android.sh all'; single-ABI builds are development-only and intentionally invalidate this stamp." />
    <Error Condition="!Exists('%(_JaliumAndroidPayloadStamp.Identity)')"
           Text="The complete Jalium Android native payload for ABI '%(_JaliumAndroidPayloadStamp.Abi)' was not found. Missing stamp: '%(_JaliumAndroidPayloadStamp.Identity)'. Run src/native/build-android.sh before building or packing." />
    <Error Condition="'%(AndroidNativeLibrary.JaliumRequired)' == 'true' and !Exists('%(AndroidNativeLibrary.Identity)')"
           Text="The complete Jalium Android native payload for ABI '%(AndroidNativeLibrary.Abi)' is missing required library '%(AndroidNativeLibrary.Identity)'. Rebuild the ABI with src/native/build-android.sh." />
  </Target>

  <!-- Fail the pack when a packed .so is stale relative to git history
       (-p:JaliumAllowStaleNative=true downgrades to warnings). The NDK pin
       and ABI/API flags live in build-android.sh, so it counts as a build
       input for every Android binary. -->
  <PropertyGroup>
    <JaliumNativeGuardExtraPathSpec>src/native/build-android.sh</JaliumNativeGuardExtraPathSpec>
  </PropertyGroup>
  <Import Project="$(MSBuildThisFileDirectory)../../../eng/msbuild/JaliumStaleNativeGuard.targets" />

</Project>
