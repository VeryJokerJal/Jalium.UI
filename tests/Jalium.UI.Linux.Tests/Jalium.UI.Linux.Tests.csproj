<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <!-- Framework internals are intentionally exposed to Jalium.UI.Tests. Use
         the same test assembly identity for the portable Linux slice. -->
    <AssemblyName>Jalium.UI.Tests</AssemblyName>
    <RootNamespace>Jalium.UI.Tests</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Build.Framework" Version="18.4.0" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="18.4.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.3.0" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\managed\Jalium.UI.Build\Jalium.UI.Build.csproj"
                      AdditionalProperties="BuildJaliumNativeProjects=false;BuildJaliumNativeStaticProjects=false" />
    <ProjectReference Include="..\..\src\managed\Jalium.UI.Core\Jalium.UI.Core.csproj" />
    <ProjectReference Include="..\..\src\managed\Jalium.UI.Controls\Jalium.UI.Controls.csproj" />
    <ProjectReference Include="..\..\src\managed\Jalium.UI.Gpu\Jalium.UI.Gpu.csproj" />
    <ProjectReference Include="..\..\src\managed\Jalium.UI.Interop\Jalium.UI.Interop.csproj" />
    <ProjectReference Include="..\..\src\managed\Jalium.UI.Media\Jalium.UI.Media.csproj" />
    <ProjectReference Include="..\..\src\managed\Jalium.UI.Xaml\Jalium.UI.Xaml.csproj" />
  </ItemGroup>

  <!--
    Keep the portable suite coupled to the complete source inventory. New tests
    are included automatically; the exclusion list below is the auditable set
    of tests that genuinely require a Windows-only harness or desktop API.
  -->
  <ItemGroup>
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\DeviceLost\**\*.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\EffectCaptureCullOverrideTests.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\FileDialogComActivationTests.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\SpellCheckerComActivationTests.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\UiaComWrappersTests.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\VulkanEffectGpuRtSmokeTests.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\VulkanPerCornerReplayTests.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\VulkanRetainedLayerParityTests.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\VulkanStrokeAlignmentTests.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\VulkanSuperEllipseAntialiasingTests.cs" />
    <_WindowsOnlyTestSource Include="..\Jalium.UI.Tests\WindowTaskbarRelaunchTests.cs" />

    <Compile Include="..\Jalium.UI.Tests\**\*.cs"
             Exclude="..\Jalium.UI.Tests\bin\**;..\Jalium.UI.Tests\obj*\**;@(_WindowsOnlyTestSource)"
             LinkBase="" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\Jalium.UI.Tests\TestAssets\**\*.jalxaml"
                      Link="TestAssets\%(RecursiveDir)%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\Jalium.UI.Tests\TestAssets\ApplicationResource.txt"
                      Link="TestAssets\ApplicationResource.txt" />
    <EmbeddedResource Include="..\Jalium.UI.Tests\TestAssets\SplashScreen.bmp"
                      Link="TestAssets\SplashScreen.bmp" />
  </ItemGroup>

</Project>
