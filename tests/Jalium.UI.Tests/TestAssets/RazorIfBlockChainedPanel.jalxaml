<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel>
    @if(IsOnline){
    <Border x:Name="OnlineBorder" Width="120" Height="30" />
    } @if(!IsOnline){
    <Border x:Name="OfflineBorder" Width="120" Height="30" />
    }
  </StackPanel>
</UserControl>
