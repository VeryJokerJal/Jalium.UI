<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel>
    @if(IsOnline){<Border x:Name="OnlineBorder" Width="120" Height="30"><TextBlock Text="Online" /></Border>} @if(!IsOnline){<Border x:Name="OfflineBorder" Width="120" Height="30"><TextBlock Text="Offline" /></Border>}
  </StackPanel>
</UserControl>
